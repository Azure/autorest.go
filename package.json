{
  "name": "@autorest.go/monorepo",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "type": "module",
  "scripts": {
    "build:all": "pnpm -r build",
    "modtidy": "node .scripts/modtidy.js",
    "buildvet": "node .scripts/buildvet.js",
    "gogetu": "node .scripts/gogetu.js",
    "gotest": "node .scripts/gotest.js",
    "format": "prettier --write \"packages/*/src/**/*.ts\" \"packages/*/test/**/*.ts\" && pnpm -r eslint-fix",
    "format:check": "prettier --check \"packages/*/src/**/*.ts\" \"packages/*/test/**/*.ts\" && pnpm -r eslint"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@types/node": "catalog:",
    "prettier": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "lodash": ">=4.18.1 <5",
      "yaml": ">=2.8.3 <3",
      "picomatch@2": ">=2.3.2 <3",
      "picomatch@4": ">=4.0.4 <5",
      "brace-expansion@2": ">=2.0.3 <3",
      "underscore": ">=1.13.8 <2",
      "uuid": ">=11.1.1 <12"
    }
  }
}